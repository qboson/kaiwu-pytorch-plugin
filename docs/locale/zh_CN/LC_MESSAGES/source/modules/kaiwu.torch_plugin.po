msgstr "基类：:py:class:`~kaiwu.torch_plugin.abstract_boltzmann_machine.AbstractBoltzmannMachine`"

#: kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine:1 of
msgid "Boltzmann Machine."
msgstr "玻尔兹曼机。"

#: kaiwu.torch_plugin.dbn.UnsupervisedDBN:5 kaiwu.torch_plugin.dbn.UnsupervisedDBN.create_rbm_layer:3 kaiwu.torch_plugin.dbn.UnsupervisedDBN.forward:3 kaiwu.torch_plugin.dbn.UnsupervisedDBN.get_rbm_layer:3 kaiwu.torch_plugin.dbn.UnsupervisedDBN.reconstruct:3 kaiwu.torch_plugin.dbn.UnsupervisedDBN.reconstruct_with_rbm:3 kaiwu.torch_plugin.dbn.UnsupervisedDBN.transform:3 kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine:3 kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.clip_parameters:3 kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.condition_sample:3 kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.forward:3 kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.gibbs_sample:3 kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.hidden_bias:3 kaiwu.torch_plugin.full_boltzmann_machine.BoltzmannMachine.visible_bias:3 kaiwu.torch_plugin.qdiffusion.QDiffusion.energy:3 kaiwu.torch_plugin.qdiffusion.QDiffusion.forward:3
