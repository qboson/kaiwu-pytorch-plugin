#~ msgid ""
#~ "\\sum_{j \\neq i} w_{ij} \\xi_j^\\mu ="
#~ " \\frac{1}{N} \\sum_{j \\neq i} "
#~ "\\sum_{\\nu=1}^P \\xi_i^\\nu \\xi_j^\\nu \\xi_j^\\mu"
#~ msgstr ""
#~ "考虑一个存储模式 $\\boldsymbol{\\xi}^\\mu$。在 Hebbian "
